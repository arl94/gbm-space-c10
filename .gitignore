# Build/scratch machinery. A few builder scripts are tracked explicitly with `git add -f`.
scratch_build/
__pycache__/
*.pyc
.ipynb_checkpoints/
*.log

# Vendored third-party package (install via pip: BASIS==0.3.2); not course material.
BASIS/

# Level 3 BASIS segmentation notebook. Not part of the released course material: it needs the
# complete raw Xenium output folders (~40 GB of morphology TIFFs / zarr) that the data bundle
# deliberately leaves out. See README.md "What is not included".
notebooks/level3/04_xenium_segmentation_basis_solution.ipynb

# Datasets are distributed separately -- see scripts/fetch_c10_data.sh and data/README.md.
# The whole data/ tree is fetched, not tracked; only its README travels with the repo.
data/*
!data/README.md
*.h5ad
*.h5ad.gz

# GPU-step outputs: too large for git (2 files >100 MB). Fetched with the data bundle.
precomputed/*
!precomputed/README.md
